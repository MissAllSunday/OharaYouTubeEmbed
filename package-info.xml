<?xml version="1.0" ?>
<!DOCTYPE package-info SYSTEM "http://www.simplemachines.org/xml/package-info">

<package-info xmlns="http://www.simplemachines.org/xml/package-info" xmlns:smf="http://www.simplemachines.org/">

	<name>Ohara YouTube Embed</name>
	<id>Suki:ohara_youtube_embed</id>
	<version>2.1</version>
	<type>modification</type>

	<install for="2.1 - 2.1.99">
		<readme parsebbc="true">readme.txt</readme>
		<license type="inline" parsebbc="false">
This Source Code Form is subject to the terms of the Mozilla Public
License, v. 2.0. If a copy of the MPL was not distributed with this
file, You can obtain one at http://mozilla.org/MPL/2.0/.
		</license>
		<code>installCheck.php</code>
		<credits url="https://missallsunday.com" license="MPL 2.0" copyright="Michel Mendiola" licenseurl="https://www.mozilla.org/MPL/2.0/">
			Ohara YouTube Embed mod
		</credits>
		<hook hook="integrate_pre_include" file="$boarddir/oharayt_vendor/autoload.php"  />
		<hook hook="integrate_bbc_codes"
		      function="OharaYTEmbed\OharaYTEmbed::addCode#" />
		<hook hook="integrate_bbc_buttons"
		      function="OharaYTEmbed\OharaYTEmbed::addButtons#" />
		<hook hook="integrate_general_mod_settings"
		      function="OharaYTEmbed\OharaYTEmbed::addSettings#" />
		<hook hook="integrate_pre_parsebbc"
		      function="OharaYTEmbed\OharaYTEmbed::addEmbed#" />
		<require-dir name="oharayt_vendor" destination="$boarddir">Dependencies files</require-dir>
		<require-dir name="Themes" destination="$boarddir">Theme and Language files</require-dir>
		<require-dir name="Sources/OharaYTEmbed" destination="$sourcedir">Source library and site plugins</require-dir>
		<require-dir name="oharayt_vendor" destination="$boarddir">Composer vendor folder</require-dir>
		<redirect url="index.php?action=admin;area=modsettings;sa=general" timeout="1000" />
	</install>

	<uninstall for="2.1 - 2.1.99">
		<hook hook="integrate_bbc_codes"
		      function="OharaYTEmbed\OharaYTEmbed::addCode#" reverse="true" />
		<hook hook="integrate_bbc_buttons"
		      function="OharaYTEmbed\OharaYTEmbed::addButtons#" reverse="true" />
		<hook hook="integrate_general_mod_settings#"
			  function="OharaYTEmbed\OharaYTEmbed::addSettings#" />
		<hook hook="integrate_pre_parsebbc"
		      function="OharaYTEmbed\OharaYTEmbed::addEmbed#"  reverse="true" />
		<remove-dir name="$sourcedir/OharaYTEmbed" />
		<remove-dir name="$boarddir/oharayt_vendor" />
		<remove-file name="$languagedir/OharaYTEmbed.english.php" />
		<remove-file name="$languagedir/OharaYTEmbed.spanish_es.php" />
		<remove-file name="$languagedir/OharaYTEmbed.spanish_latin.php" />
		<remove-file name="$languagedir/OharaYTEmbed.russian.php" />
		<remove-file name="$themedir/scripts/OharaYTEmbed.js" />
		<remove-file name="$themedir/css/OharaYTEmbed.css" />
	</uninstall>
</package-info>
